<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="2026.05.11-0" author="gFiras" failOnError="true">
        <createTable tableName="refresh_token" schemaName="public">
            <column name="refresh_token_id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="fk_person_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="token_hash" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="expires_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableSchemaName="public"
                                 baseTableName="refresh_token"
                                 baseColumnNames="fk_person_id"
                                 constraintName="fk_refresh_token_person"
                                 referencedTableSchemaName="public"
                                 referencedTableName="person"
                                 referencedColumnNames="person_id"/>
        <createIndex indexName="idx_refresh_token_expires_at" schemaName="public" tableName="refresh_token">
            <column name="expires_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
